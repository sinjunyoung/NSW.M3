<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:l="clr-namespace:NSW.Core.Properties;assembly=NSW.Core"
             xmlns:vm="clr-namespace:NSW.Avalonia.ViewModels"
             xmlns:ui="clr-namespace:NSW.Avalonia.UI"
             mc:Ignorable="d" d:DesignHeight="400" d:DesignWidth="800"
             x:Class="NSW.Avalonia.UI.FileManagerControl"
             x:DataType="vm:FileManagerViewModel"
			 
             FontFamily="Consolas">

	<UserControl.Resources>
		<DataTemplate x:Key="TypeCellTemplate" x:DataType="vm:GameFile">
			<Border CornerRadius="4" Padding="6,2"
                    Background="{Binding TypeBackground}"
                    HorizontalAlignment="Left" VerticalAlignment="Center">
				<TextBlock Text="{Binding FileType}"
                           FontSize="11"
                           FontFamily="Consolas"
                           Foreground="{Binding TypeForeground}"/>
			</Border>
		</DataTemplate>
	</UserControl.Resources>

	<UserControl.Styles>
		<Style Selector="DataGridColumnHeader">
			<Setter Property="Background" Value="#1AFFFFFF"/>
			<Setter Property="Foreground" Value="#A0A0A0"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Padding" Value="8,5"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
		</Style>
	</UserControl.Styles>

	<Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="8"
            Background="#12FFFFFF" Padding="10">
		<Grid ColumnDefinitions="*, Auto, 160, Auto, Auto">			
			<Panel Grid.Column="0">
				<StackPanel Name="dropHint" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.7" IsHitTestVisible="False" ZIndex="1" IsVisible="{Binding !GameFiles.Count}">
					<Image Source="/Assets/Images/Drag.png" Width="32" Height="32" Margin="0,0,0,10" RenderOptions.BitmapInterpolationMode="HighQuality" />
					<TextBlock Text="{x:Static l:Resources.Hint_DragAndDrop}"
                               FontSize="11" HorizontalAlignment="Center"/>
				</StackPanel>

				<DataGrid x:Name="lvFiles"
                          ItemsSource="{Binding GameFiles}"
                          SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                          Background="Transparent"
                          Foreground="#DCDCDC"
                          BorderThickness="1"
                          CanUserResizeColumns="True"
                          AutoGenerateColumns="False"
                          SelectionMode="Extended"
                          DragDrop.AllowDrop="True"
                          KeyUp="LvFiles_KeyUp"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
					<DataGrid.Columns>
						<DataGridTemplateColumn Header="{x:Static l:Resources.Header_Type}" Width="80" CellTemplate="{StaticResource TypeCellTemplate}" SortMemberPath="FileType"/>
						<DataGridTemplateColumn Header="{x:Static l:Resources.Header_FileName}" Width="Auto" MaxWidth="450" SortMemberPath="FileName">
							<DataGridTemplateColumn.CellTemplate>
								<DataTemplate x:DataType="vm:GameFile">
									<TextBlock Text="{Binding FileName}" FontSize="11" VerticalAlignment="Center" Padding="5,0" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding FileName}"/>
								</DataTemplate>
							</DataGridTemplateColumn.CellTemplate>
						</DataGridTemplateColumn>
						<DataGridTemplateColumn Header="{x:Static l:Resources.Header_Ext}" Width="Auto" SortMemberPath="Extension">
							<DataGridTemplateColumn.CellTemplate>
								<DataTemplate>
									<Border Background="{Binding ExtensionColor}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
										<TextBlock Text="{Binding Extension}"
												   FontSize="11"
												   Margin="10,0"
												   VerticalAlignment="Center"/>
									</Border>
								</DataTemplate>
							</DataGridTemplateColumn.CellTemplate>
						</DataGridTemplateColumn>
						<DataGridTextColumn Header="{x:Static l:Resources.Header_Size}" Width="Auto" Binding="{Binding FileSize}" FontSize="11" SortMemberPath="RawBytes"/>
						<DataGridTemplateColumn Header="{x:Static l:Resources.Header_FilePath}" Width="Auto" MaxWidth="400" SortMemberPath="FilePath">
							<DataGridTemplateColumn.CellTemplate>
								<DataTemplate x:DataType="vm:GameFile">
									<TextBlock Text="{Binding FilePath}" FontSize="11" VerticalAlignment="Center" Padding="5,0" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding FilePath}"/>
								</DataTemplate>
							</DataGridTemplateColumn.CellTemplate>
						</DataGridTemplateColumn>
					</DataGrid.Columns>
				</DataGrid>
			</Panel>

			<Rectangle Grid.Column="1" VerticalAlignment="Stretch" Width="1" Fill="#33FFFFFF"/>
			
			<Border Grid.Column="2" VerticalAlignment="Top">
				<StackPanel>
					<Border CornerRadius="15" ClipToBounds="True" Margin="1">
						<Image Source="{Binding SelectedGame.CoverBitmap}"
							   Stretch="Uniform"
							   RenderOptions.BitmapInterpolationMode="HighQuality"
							   PointerPressed="IconImage_PointerPressed"></Image>
					</Border>

					<StackPanel Margin="10,10,10,0">
						<TextBlock Text="{Binding SelectedGame.TitleName}"
								   FontSize="11"
								   FontWeight="Bold"
								   Foreground="White"
								   TextWrapping="Wrap"
								   HorizontalAlignment="Center"
								   TextAlignment="Center"
								   Margin="0,0,0,4"/>

						<TextBlock Text="{Binding SelectedGame.TitleId}"
								   FontSize="10"
								   Foreground="#A0A0A0"
								   HorizontalAlignment="Center"
								   ToolTip.Tip="Title ID"/>

						<TextBlock Text="{Binding SelectedGame.Version, StringFormat='Ver {0}'}"
								   FontSize="10"
								   Foreground="#80FFFFFF"
								   HorizontalAlignment="Center"
								   Margin="0,2,0,0"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<Rectangle Grid.Column="3" VerticalAlignment="Stretch" Width="1" Fill="#33FFFFFF"/>

			<StackPanel Grid.Column="4" Margin="5,0,0,0" VerticalAlignment="Top">
				<Button Name="btnAddFile" Width="32" Height="32" Margin="0,0,0,12" Background="Transparent" BorderThickness="0"
                        Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Click="BtnAddFile_Click" ToolTip.Tip="{x:Static l:Resources.ToolTip_AddFile}">
					<Image Source="/Assets/Images/AddFile.png" Width="32" Height="32" Stretch="Fill" RenderOptions.BitmapInterpolationMode="HighQuality" />
				</Button>
				<Button Name="btnRemoveFile" Width="32" Height="32" Margin="0,0,0,12" Background="Transparent" BorderThickness="0"
                        Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Click="BtnRemoveFile_Click" ToolTip.Tip="{x:Static l:Resources.ToolTip_RemoveSelected}">
					<Image Source="/Assets/Images/DeleteFile.png" Width="32" Height="32" Stretch="Fill" RenderOptions.BitmapInterpolationMode="HighQuality" />
				</Button>
				<Button Name="btnRemoveAllFiles" Width="32" Height="32" Margin="0,0,0,12" Background="Transparent" BorderThickness="0"
                        Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Click="BtnRemoveAllFiles_Click" ToolTip.Tip="{x:Static l:Resources.ToolTip_RemoveAll}">
					<Image Source="/Assets/Images/DeleteAllFile.png" Width="32" Height="32" Stretch="Fill" RenderOptions.BitmapInterpolationMode="HighQuality" />
				</Button>

				<Button Name="btnExtra" Width="32" Height="32" IsVisible="False"
                        Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Click="BtnExtra_Click">
					<TextBlock Text="✨" FontSize="18"/>
				</Button>
			</StackPanel>
		</Grid>
	</Border>
</UserControl>